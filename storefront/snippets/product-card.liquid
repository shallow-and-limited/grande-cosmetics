{% comment %}
  @param product {Product}
  @param class {String}
  @param attr {String}
{% endcomment %}
{%- liquid
  assign _metafields = product.metafields.details
  assign featured_media = product.featured_media.preview_image
-%}

{{ 'product-card.min.css' | asset_url | stylesheet_tag }}

<product-card class="product-card {{ class }}" {{ attr }} 
    data-product="{{ product.id }}" 
  >
  <div class="product-card__images">
    {% render 'product-badges', product: product %}

    {%- if _metafields.award_image != blank -%}
      <span class="product-card__award">
        {% render 'image', image: _metafields.award_image %}
      </span>
    {%- endif -%}
    <a href="{{ product.url }}" class="product-card__link" aria-label="{{ product.title }}" data-card-link>     
      <img
        srcset="
          {%- if featured_media.width >= 165 -%}{{ featured_media | image_url: width: 165 }} 165w,{%- endif -%}
          {%- if featured_media.width >= 360 -%}{{ featured_media | image_url: width: 360 }} 360w,{%- endif -%}
          {%- if featured_media.width >= 533 -%}{{ featured_media | image_url: width: 533 }} 533w,{%- endif -%}
          {%- if featured_media.width >= 720 -%}{{ featured_media | image_url: width: 720 }} 720w,{%- endif -%}
          {%- if featured_media.width >= 940 -%}{{ featured_media | image_url: width: 940 }} 940w,{%- endif -%}
          {%- if featured_media.width >= 1066 -%}{{ featured_media | image_url: width: 1066 }} 1066w{%- endif -%}
        "
        src="{{ featured_media | image_url: width: 533 }}"
        sizes="(min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
        alt="{{ featured_media.alt | escape }}"
        class="product-card__image product-card__image--primary"
        loading="lazy"
        width="{{ featured_media.width }}"
        height="{{ featured_media.height }}"
      />

      {%- if product.media[1].preview_image != blank -%}
        <img
          srcset="
            {%- if product.media[1].preview_image.width >= 165 -%}{{ product.media[1].preview_image | image_url: width: 165 }} 165w,{%- endif -%}
            {%- if product.media[1].preview_image.width >= 360 -%}{{ product.media[1].preview_image | image_url: width: 360 }} 360w,{%- endif -%}
            {%- if product.media[1].preview_image.width >= 533 -%}{{ product.media[1].preview_image | image_url: width: 533 }} 533w,{%- endif -%}
            {%- if product.media[1].preview_image.width >= 720 -%}{{ product.media[1].preview_image | image_url: width: 720 }} 720w,{%- endif -%}
            {%- if product.media[1].preview_image.width >= 940 -%}{{ product.media[1].preview_image | image_url: width: 940 }} 940w,{%- endif -%}
            {%- if product.media[1].preview_image.width >= 1066 -%}{{ product.media[1].preview_image | image_url: width: 1066 }} 1066w,{%- endif -%}
            {{ product.media[1].preview_image | image_url }} {{ product.media[1].preview_image.width }}w
          "
          src="{{ product.media[1].preview_image | image_url: width: 533 }}"
          sizes="(min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
          alt="{{ product.media[1].preview_image.alt | escape }}"
          class="product-card__image  product-card__image--secondary"
          loading="lazy"
          width="{{ product.media[1].preview_image.width }}"
          height="{{ product.media[1].preview_image.height }}"
        />
      {%- endif -%}
    </a>
  </div>
  <div class="product-card__content">
    <div class="product-card__text">
      <p class="product-card__title p-3 color-dark-gray">{{ product.title | split: ' - ' | first }}</p>
      <p class="product-card__subtitle p-2">{{ product.metafields.details.subtitle }}</p>
      {% unless isCarousel %}
        <div class="hide-desktop p-3">
          {% render 'price', target: product.selected_or_first_available_variant, show_trailing_zeros: true %}
        </div>
      {% endunless %}
    </div>

    {% if product.selected_or_first_available_variant.available == false or template == 'search' or template == 'collection' and product.variants > 1 %}
      {% render 'product-card-product-options', product: product, id: formId %}
      {% render 'product-card-buy-button', product: product %}

    {% else %}
      <form method="post" action="/cart/add" data-add-to-cart-form>
        <input
          type="hidden"
          name="id"
          value="{{ product.selected_or_first_available_variant.id }}"
          data-selected-variant-id
        >
        <input
          type="hidden"
          name="quantity"
          id="quantity"
          value="1"
          data-quantity
        >
        <button data-add-to-cart-btn class="product-card__atb btn btn--secondary p-3">
          Add to Bag
          <span class="{% unless isCarousel %}hide-mobile{% endunless %}">
            •
            {% render 'price', target: product.selected_or_first_available_variant, show_trailing_zeros: true, product_card: true %}
          </span>
        </button>
      </form>
    {% endif %}
  </div>
</product-card>

<script src="{{ 'product-card.min.js' | asset_url }}" defer="defer"></script>
