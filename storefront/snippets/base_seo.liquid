{% if template == 'product' and product.metafields.inventory.ShappifyHidden or product.type contains '_HIDDEN_' or product.tags contains "hidden" -%}
  <meta name="robots" content="nofollow,noindex">
{%- endif %}

<link rel="canonical" href="{{ canonical_url }}">

<title>
  {{ page_title }}
  {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
  {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
  {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
</title>

{%- if settings.favicon != blank -%}
  <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 16, height: 16 }}" sizes="16x16">
  <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}" sizes="32x32">
  <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 192, height: 192 }}" sizes="192x192">
  <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 194, height: 194 }}" sizes="194x194">

  <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 57, height: 57 }}" sizes="57x57">
  <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 60, height: 60 }}" sizes="60x60">
  <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 72, height: 72 }}" sizes="72x72">
  <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 76, height: 76 }}" sizes="76x76">
  <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 114, height: 114 }}" sizes="114x114">
  <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 120, height: 120 }}" sizes="120x120">
  <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 152, height: 152 }}" sizes="152x152">
  <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180 }}" sizes="180x180">
{%- endif -%}

{% if page_description %}
  <meta name="description" content="{{ page_description | escape }}">
{% endif %}
