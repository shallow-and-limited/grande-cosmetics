<modal-dialog id="{{ id }}" class="modal">
  <div
    role="dialog"
    aria-label="{{ title }}"
    aria-modal="true"
    class="modal__container {{ settings.dialog_color_scheme }}"
    tabindex="-1"
  >
    <button
      id="ModalClose-{{ id }}"
      type="button"
      class="link modal__close"
      aria-label="{{ 'accessibility.close' | t }}"
    >
      {% render 'icon-close' %}
    </button>
    <div class="modal__content">
      {{ content }}
    </div>
  </div>
</modal-dialog>
