{%- liquid
    assign variants_available_arr = product.variants | map: 'available'
    assign variants_option1_arr = product.variants | map: 'option1'
    assign variants_option2_arr = product.variants | map: 'option2'
    assign variants_option3_arr = product.variants | map: 'option3'
    assign variant_ids = ''
    for variant in product.variants
      assign variant_ids = variant_ids | append: variant.id | append: ','
    endfor
    assign variant_ids_array = variant_ids | split: ','
  -%}
  
  {%- unless product.has_only_default_variant -%}
    <div class="product-form__options-wrapper">
      {%- for option in product.options_with_values -%}
        {% if option.name contains 'Color' or option.name contains 'color' %}
          <div class="product-form__option-label product-form__color-label p-4">
            {{ option.name }}:
            <span class="w-bold" data-selected-color>{{ option.selected_value }}</span>
          </div>
          <div class="product-form__swatches" data-swatches>
            {% for value in option.values %}
              {% liquid
                for variant in product.variants
                  if variant.options contains value
                    assign _variant = variant
                    break
                  endif
                endfor
                assign _metafields = _variant.metafields.details
  
                assign swatch_image = ''
                assign swatch_code = ''
                if _metafields.swatch_image != blank
                  assign swatch_image = _metafields.swatch_image
                elsif _metafields.swatch_hex_code != blank
                  assign swatch_code = _metafields.swatch_hex_code
                endif
              %}
              <button 
                class="product-form__swatch swatch {% if forloop.first %}swatch--selected{% endif %}" 
                data-swatch="{{ value }}"
                data-available="{{ _variant.available }}"
                data-option="{{ option.name }}"
                id="{{ _variant.id }}"
                value="{{ _variant.id }}"
                price="{{ _variant.price }}"
                name="{{ product.title }}"
                data-variant-title="{{ value }}"
                {% if forloop.first %}data-selected{% endif %}
              >
                <div class="swatch__inner" {% if swatch_code != blank %}style="background-color: {{ swatch_code }};"{% endif %}>
                  {% if swatch_image != blank %}
                    {{ swatch_image | image_url: width: swatch_image.width | image_tag: class: 'swatch__image' }}
                  {% endif %}
                </div>
              </button>
            {% endfor %}
          </div>
        {% else %}
          <div class="product-form__quantity-guide space-between">
            <span class="p-4">
              {{ option.name }}:
              <span class="w-bold" data-selected-option="{{ option.name }}">{{ option.selected_value }}</span>
              {% if product.variants.first.metafields.details.supply != blank %}
                is a <span class="w-bold"><span data-supply>{{ product.variants.first.metafields.details.supply }}</span> Supply</span>
              {% endif %}
            </span>
          </div>
          <tabs-element class="tabs tabs--pdp" data-carousel="false">
            {%- for value in option.values -%}
              {%- liquid
                assign option_disabled = true
  
                for option1_name in variants_option1_arr
                  case option.position
                    when 1
                      if variants_option1_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
                        assign option_disabled = false
                      endif
                    when 2
                      if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
                        assign option_disabled = false
                      endif
                    when 3
                      if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == product.selected_or_first_available_variant.option2 and variants_option3_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
                        assign option_disabled = false
                      endif
                  endcase
                endfor
                assign currentIndex = forloop.index | minus: 1
                assign variant = product.variants[currentIndex]
              -%}
              <label for="{{ variant.id }}" class="p-3 tab {% if product.selected_or_first_available_variant.id == variant.id %}tab--selected{% endif %} {% if option_disabled %}tab--disabled{% endif %}" data-tab>{{ value }}</label>
              <input 
                style="display:none;"
                type="radio"
                id="{{ variant.id }}"
                value="{{ variant.id }}"
                price="{{ variant.price }}"
                class="{% if option_disabled %}disabled{% endif %}"
                data-option="{{ option.name }}"
                data-supply="{{ variant.metafields.details.supply }}"
                name="{{ product.title }}"
                data-variant-title="{{ value }}"
                {% if product.selected_or_first_available_variant.id == variant.id %}checked{% endif %}
                role="option"
              />
            {%- endfor -%}
          </tabs-element>
          <script src="{{ 'tabs-element.min.js' | asset_url }}" defer="defer"></script>
  
  
          {% if option.name == 'style' or option.name == 'Style' %}
            {% assign productTags = product.tags | join: ',' %}
          {% endif %}
        {% endif %}
      {%- endfor -%}
    </div>
  {% endunless %}
  <div class="product-form__error-message-wrapper" role="alert" hidden data-cart-error-wrapper>
    <span class="product-form__error-message"></span>
  </div>
  