        "content_9DqK4W": {
          "type": "content",
          "settings": {
            "image_first": false,
            "video_url": "",
            "video_autoplay": false,
            "heading": "Our Story",
            "heading_size": "h2",
            "text": "<p>Founded in New York City in 1985 by London-born brothers David and Malcolm Samad, our family-owned business is rooted in four generations of rug-making expertise. Inspired by the legacy of their father, Eric Samad, the brothers emigrated to the U.S. with a shared vision: to create the world’s finest handmade rugs.</p>",
            "text_style": "body",
            "mobile_text_style": "body--mobile",
            "button_label": "Learn More",
            "button_link": "shopify://pages/aboutus",
            "button_style_secondary": false,
            "button_label_2": "",
            "button_link_2": "",
            "button_style_secondary_2": false,
            "box_color_scheme": "",
            "desktop_content_position": "middle",
            "desktop_content_alignment": "left",
            "content_layout": "no-overlap",
