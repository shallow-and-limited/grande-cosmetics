{{ 'article.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {%- if section.settings.aspect_ratio == 'adapt' -%}
    @media screen and (min-width: 750px) {
      #{{ section.id }} .media--adapt {
        {% if article.image != blank %}
          padding-bottom: {{ 1 | divided_by: article.image.aspect_ratio | times: 100 }}%;
        {% else %}
          padding-bottom: 66%;
        {% endif %}
      }
    }
  {%- endif -%}

  {%- if section.settings.aspect_ratio_mobile == 'adapt' -%}
    @media screen and (max-width: 749px) {
      #{{ section.id }} .media--adapt {
        {% if article.image != blank %}
          padding-bottom: {{ 1 | divided_by: article.image.aspect_ratio | times: 100 }}%;
        {% else %}
          padding-bottom: 66%;
        {% endif %}
      }
    }
  {%- endif -%}
{%- endstyle -%}

{%- render 'section_padding' %}

{%- assign widths = '400, 800, 1200, 1600, 2000, 2400, 2800, 3200, 3840' -%}

{%- capture sizes -%}
  {%- if section.settings.layout == "large-width" -%}
    (min-width: {{ settings.large_width }}px) {{ settings.large_width }}px,
  {%- elsif section.settings.layout == "page-width" -%}
    (min-width: {{ settings.page_width }}px) {{ settings.page_width }}px,
  {%- endif -%}
  100vw
{%- endcapture %}

<div
  id="{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding"
>
  <div class="article__header">
    <div class="article__header-image">
      <div class="media media--{{ section.settings.aspect_ratio }} media--{{ section.settings.aspect_ratio_mobile }}-mobile">
        {%- if article.image != blank -%}
          {%- assign image_height = article.image.width | divided_by: image.aspect_ratio -%}
          {{
            article.image
            | image_url: width: 3840
            | image_tag:
            width: article.image.width,
            height: image_height,
            sizes: sizes,
            widths: widths,
            fetchpriority: 'high',
            lazy: true
          }}
        {%- endif -%}
      </div>
    </div>

    <div class="article__header-content">
      <div class="
          {{ section.settings.heading_alignment }}
          section__header
          {{ section.settings.layout }}
        ">
        <h1 class="section__title">
          {{ section.settings.title | default: article.title }}
        </h1>

        {%- if section.settings.description != blank -%}
          <div class="section__description {{ section.settings.text_style }} {{ section.settings.mobile_text_style }}">
            {{ section.settings.description }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div
    class="{{ section.settings.layout }} isolate {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    <div class="article__content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            <div
              class="article__block article__block--app"
              {{ block.shopify_attributes }}
            >
              {% render block %}
            </div>
          {%- when 'content' -%}
            <div
              class="article__block article__block--content"
              {{ block.shopify_attributes }}
            >
              {{ article.content }}
            </div>
          {%- when 'social' -%}
            <div class="article__block article__block--social">
              <div class="article__social-title body body--large">
                {{ block.settings.title }}
              </div>

              <ul class="article__social-icons list--unstyled">
                <li class="article__social-icon">
                  <a
                    target="_blank"
                    class="link"
                    href="http://twitter.com/share?text={{ article.title }}&url={{ shop.url | append: page.url | append: article.url }}"
                  >
                    <span class="visually-hidden">Share on Twitter</span>
                    {%- render 'icon-twitter' -%}
                  </a>
                </li>
                <li class="article__social-icon">
                  <a
                    target="_blank"
                    class="link"
                    href="http://www.facebook.com/sharer.php?u={{ shop.url }}{{ article.url }}"
                  >
                    <span class="visually-hidden">Share on Facebook</span>
                    {%- render 'icon-facebook' -%}
                  </a>
                </li>
              </ul>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

