{{ 'tabs.css' | asset_url | stylesheet_tag }}

{%- render "section_padding" %}

<div
  id="{{ section.id }}" 
  class="
    section
    color-{{ section.settings.color_scheme }}
    gradient
  "
>
  <div class="{{ section.settings.layout }}">
    {% content_for 'block', type: '_section-header', id: 'section-header' %}

    <tabs-element 
      class="tabs-element"
      style='
        --tabs-margin-bottom: {{ section.settings.margin_bottom }}rem;
      '
    >
      <slider-component class='tabs-slider'>
        <div 
          class="
            grid
            slider 
            slider--mobile 
            slider--desktop
            tabs
          " 
          role="tablist"
        >
          {% content_for "blocks" %}
        </div>
      </slider-component>
    </tabs-element>    
  </div>
</div>

{% schema %}
{
  "name": "Tabbed Content",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.general.section_settings"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.general.color_scheme"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.general.layout",
      "options": [
        { "value": "page-width", "label": "t:sections.general.default" },
        { "value": "full-width", "label": "t:sections.general.full_width" },
        { "value": "screen-width", "label": "t:sections.general.screen_width" },
        { "value": "narrow-width", "label": "t:sections.general.narrow_width" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:sections.general.section_spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 4,
      "step": 0.1,
      "unit": "rem",
      "label": "t:sections.general.padding_top",
      "default": 2
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 4,
      "step": 0.1,
      "unit": "rem",
      "label": "t:sections.general.padding_bottom",
      "default": 2
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 4,
      "step": 0.1,
      "unit": "rem",
      "label": "t:sections.general.margin_bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "_tabs-link"
    },
  ],  
  "presets": [
    {
      "name": "Tabbed Links",
      "category": "Content"
    }
  ],
  "disabled_on": {
    "groups": ["footer", "header"]
  }
}
{% endschema %}
