{{ 'footer.min.css' | asset_url | stylesheet_tag }}
{{ 'accordion-tab.min.css' | asset_url | stylesheet_tag }}

{% liquid
  assign _settings = section.settings
  assign _blocks = section.blocks
%}

<style>
  .footer__content {
    background-color: {{ _settings.background_color }};
  }
  .footer__language-selector {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 16px;
  }

  @media(min-width: 1024px) {
    .footer__language-selector {
      margin-top: 0;
    }
  }

  .footer__language-label {
    margin: 0;
  }

  .footer__language-link {
    color: var(--color-black);
  }

  .footer__language-link--selected {
    font-weight: bold;
    text-decoration: none;
  }

  .footer__language-separator {
    width: 1px;
    height: calc(1rem - 3px);
    background: var(--color-black);
  }

  .footer__language-select {
    padding: 6px 3px;
    border: 1px solid var(--color-medium-gray);
    border-radius: .5rem;
  }
</style>

<section {% if template contains 'account' or template contains 'login' or template contains 'register' or template contains 'reset' %}class="footer__wrapper"{% endif %}>
  <div class="footer{% if template contains 'account' or template contains 'login' or template contains 'register' or template contains 'reset' %} account-page{% endif %}">
    <div class="footer__wave">
      {% render 'icons', icon_name: 'wave' %}
      {% render 'icons', icon_name: 'wave', class: 'icon--flip' %}
    </div>
    <div class="footer__content">
      <div class="footer__logo-mobile hide-desktop">
        {% render 'icons', icon_name: 'footer-logo-mobile' %}
      </div>
      <div class="footer__content-main">
        <div class="footer__newsletter">
          <div class="footer__newsletter-heading p-1">{{ _settings.newsletter_heading }}</div>
          {% if _settings.klaviyo_form == blank %}
            <div class="footer__newsletter-input-wrapper">
              <input class="footer__newsletter-input p-2" name="newsletter" type="email" placeholder="Email Address" />
              <button class="footer__newsletter-submit" type="submit" for="newsletter" aria-label="Submit Email">
                {% render 'icons', icon_name: 'arrow-left-filled' %}
              </button>
            </div>
          {% else %}
            {{ _settings.klaviyo_form }}
          {% endif %}
          <div class="footer__socials">
            <a href="{{ _settings.tiktok }}" target="_blank" data-social="tiktok"><span class="footer__social-icon">{% render 'icons', icon_name: 'tiktok' %}</span></a>
            <a href="{{ _settings.instagram }}" target="_blank" data-social="instagram"><span class="footer__social-icon">{% render 'icons', icon_name: 'instagram' %}</span></a>
            <a href="{{ _settings.facebook }}" target="_blank" data-social="facebook"><span class="footer__social-icon">{% render 'icons', icon_name: 'facebook' %}</span></a>
            <a href="{{ _settings.twitter }}" target="_blank" data-social="twitter"><span class="footer__social-icon">{% render 'icons', icon_name: 'x' %}</span></a>
            <a href="{{ _settings.youtube }}" target="_blank" data-social="youtube"><span class="footer__social-icon">{% render 'icons', icon_name: 'youtube' %}</span></a>
          </div>
        </div>
        <nav class="footer__nav">
          {% if _settings.menu != blank %}
            <div class="footer__nav-desktop hide-mobile">
              {% for link in _settings.menu.links %}
                <div class="footer__nav-list">
                  <div class="footer__link p-1">{{ link.title }}</div>
                  {% if link.links != blank %}
                    <ul>
                      {% for childlink in link.links %}
                        <li><a href="{{ childlink.url }}" class="footer__childlink p-3" data-parent="{{ link.title }}">{{ childlink.title }}</a></li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
            <div class="footer__nav-mobile hide-desktop">
              {% for link in _settings.menu.links %}
                <div class="footer__nav-list">
                  <accordion-tab class="accordion-tab" data-accordion>
                    <div class="accordion-tab__title p-2" data-accordion-opener>{{ link.title }}</div>
                    {% render 'icons', icon_name: 'plus' %}
                    {% render 'icons', icon_name: 'minus' %}
                      {% if link.links != blank %}
                      <ul class="accordion-tab__content">
                        {% for childlink in link.links %}
                          <li><a href="{{ childlink.url }}" class="footer__childlink p-3" data-parent="{{ link.title }}">{{ childlink.title }}</a></li>
                        {% endfor %}
                      </ul> 
                    {% endif %}
                  </accordion-tab>
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </nav>
      </div>
      <div class="footer__logo-desktop hide-mobile">
        {% render 'icons', icon_name: 'footer-logo-desktop' %}
      </div>
    </div>
    <div class="footer__legal-menu">
      <div class="footer__legal-links">
        {% for link in _settings.menu_legal.links %}
          <a href="{{ link.url }}" class="footer__legal-link p-4">{{ link.title }}</a>
        {% endfor %}
      </div>
      <div class="footer__copyright p-4 hide-mobile">{{ _settings.copyright }}&nbsp;{{ 'now' | date: '%Y' }}</div>

      {% if localization.available_languages.size > 1 or customer.email contains "@satel.ca" %}
        {%- assign current_iso = request.locale.iso_code -%}
        {%- assign current_prefix = '/' | append: current_iso -%}
        {%- assign current_prefix_with_slash = current_prefix | append: '/' -%}
        {%- assign path = request.path -%}
        {%- assign prefix_length = current_prefix_with_slash | size -%}
        {%- assign path_prefix = path | slice: 0, prefix_length -%}
        {%- if path == current_prefix -%}
          {%- assign path_without_locale = '/' -%}
        {%- elsif path_prefix == current_prefix_with_slash -%}
          {%- assign path_without_locale = path | remove_first: current_prefix -%}
        {%- else -%}
          {%- assign path_without_locale = path -%}
        {%- endif -%}

        {%- assign footer_language_id = 'footer-language-select-' | append: section.id -%}
        <div class="footer__language-selector">
          <label class="footer__language-label p-4" for="{{ footer_language_id }}">
            {{- 'localization.language_label' | t -}}
          </label>
          {% for language in localization.available_languages %}
            {%- assign url = language.root_url | append: path_without_locale -%}
            <a
              lang="{{ language.iso_code }}"
              href="{{ url | replace: '//', '/' }}"
              class="
                footer__language-link
                p-4
                {% if localization.language.iso_code == language.iso_code %}footer__language-link--selected{% endif %}
              "
            >
              {{ language.name }}
            </a>

            {% unless forloop.last %}
              <span class="footer__language-separator"></span>
            {% endunless %}           
          {% endfor %}
        </div>
      {% endif %}
    </div>
    <div class="footer__copyright-mobile hide-desktop">
      <span class="p-4">{{ _settings.copyright }}&nbsp;{{ 'now' | date: '%Y' }}</span>
      <a href="#top">{% render 'icons', icon_name: 'tapered-arrow' %}</a>
    </div>
  </div>
  <script type="text/javascript">
    usi_installed = 0; USI_installCode = function() { if (usi_installed == 0) { usi_installed = 1; var USI_headID = document.getElementsByTagName("head")[0]; var USI_installID = document.createElement('script'); USI_installID.type = 'text/javascript'; USI_installID.src = 'https://www.upsellit.com/active/grandecosmetics.jsp'; USI_headID.appendChild(USI_installID); } }; if (typeof(document.readyState) != "undefined" && document.readyState === "complete") { USI_installCode(); } else if (window.addEventListener){ window.addEventListener('load', USI_installCode, true); } else if (window.attachEvent) { window.attachEvent('onload', USI_installCode); } else { USI_installCode(); } setTimeout("USI_installCode()", 10000);
    </script>
</section>

<script src="{{ 'accordion-tab.min.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "label": "Background Color",
      "id": "background_color",
      "default": "#E6006B"
    },
    {
      "type": "select",
      "label": "Copy Color",
      "id": "color_copy",
      "default": "light",
      "options": [
        {
          "label": "light",
          "value": "light"
        },
        {
          "label": "dark",
          "value": "dark"
        }
      ]
    },
    {
      "type": "link_list",
      "label": "Main Menu",
      "id": "menu"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "label": "Newsletter Heading",
      "id": "newsletter_heading",
      "default": "Want to stay in the Know?"
    },
    {
      "type": "text",
      "label": "Klaviyo Embed Code",
      "id": "klaviyo_form",
      "default": "<div class='klaviyo-form-KGfVda'></div>"
    },
    {
      "type": "header",
      "content": "Legal"
    },
    {
      "type": "link_list",
      "label": "Legal Menu",
      "id": "menu_legal"
    },
    {
      "type": "text",
      "label": "Copyright",
      "id": "copyright",
      "info": "Date Automatically Generated"
    },
    {
      "type": "header",
      "content": "Socials"
    },
    {
      "type": "url",
      "label": "Facebook",
      "id": "facebook"
    },
    {
      "type": "url",
      "label": "Twitter",
      "id": "twitter"
    },
    {
      "type": "url",
      "label": "Youtube",
      "id": "youtube"
    },
    {
      "type": "url",
      "label": "TikTok",
      "id": "tiktok"
    },
    {
      "type": "url",
      "label": "Instagram",
      "id": "instagram"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
