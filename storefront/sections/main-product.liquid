{{ 'main-product.min.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign variant = product.selected_or_first_available_variant
  assign _metafields = product.metafields.details
  assign gid = 'gid://shopify/Product/' | append: product.id
  assign swatches = swatches | default: true, allow_false: true
  unless swatches == true
    assign swatch_class = 'main-product--no-swatches'
  endunless

  for tag in product.tags
    if tag contains 'style:'
      assign product_style = tag
      break
    endif
  endfor
-%}
<section id="top" class="main-product" data-product-top data-section-type="main-product" data-section-id="{{ section.id }}">
  <div class="main-product__wrap" data-product-id="{{ product.id }}" data-main-product>
    {% render 'media-gallery', product: product %}
    <div class="main-product__info container">
      <div class="main-product__info-wrapper">
        <product-info>
          <script
            data-section-data
            type="application/json"
          >
            {
              "style": {{ product_style | default: product_gid | json }},
              "id": {{ gid | json }}
            }
          </script>
          <div class="main-product__info-blocks">
            <div class="product-modal__overlay" data-product-modal-overlay></div>

            {%- for block in section.blocks -%}
              {% assign _b = block.settings %}
              {%- case block.type -%}
                {%- when '@app' -%}
                  {% render block %}
                  {%- when 'title' -%}
                    <div {{ block.shopify_attributes }} 
                      class="main-product__title">
                      <div class="main-product__title-wrapper">
                        <h1 class="main-product__title-text h5" data-product-title>{{ product.title }}</h1>
                      </div>
                    </div>
                    {% when 'price' %}
                      <div {{ block.shopify_attributes }} 
                        class="main-product__price p-4" data-product-prices>
                        <div class="main-product__price-wrapper">
                            {% render 'price', target: product.variants.first %}
                          <div id="tt-teaser-widget"></div>
                        </div>
                        <div class="yotpo-widget-instance" data-yotpo-instance-id="{{ settings.yotpo_instance_id }}" data-yotpo-product-id="{{product.id}}" data-yotpo-cart-product-id="{{item.product.id}}" data-yotpo-section-id="{{template.name}}"></div>
                      </div>
                    {% when 'promo-text' %}
                      {% if _metafields.promo_text != blank %}
                        <p class="p-4 main-product__promo-text color-dark-pink">{{ _metafields.promo_text }}</p>
                      {% endif %}
                    {% when 'subtitle' %}
                      <div {{ block.shopify_attributes }} class="main-product__subtitle p-3">{{ _b.subtitle }}</div>
                    {% when 'short_desc' %}
                      {% if _metafields.short_desc != blank %}
                        <div {{ block.shopify_attributes }} class="main-product__block p-4 w-bold">
                          {{ _metafields.short_desc }}
                          <a href="#prod-description" class="product-form__link">See Full Details</a>
                        </div>
                      {% endif %}
                    {% when 'promo_carousel' %}
                      {% liquid
                        assign carousel_data = _metafields.promo_carousel.value
                        if carousel_data != blank
                          render 'promo-carousel', data: carousel_data
                        endif
                      %}
                    {% when 'faqs' %}
                      {% liquid
                        assign modalID = 'faqs'
                        assign modalTitle = 'FAQs'
                        assign _faq = _metafields.faq.value
                      %}

                      {% if _faq != blank %}
                        {{ 'accordion-tab.min.css' | asset_url | stylesheet_tag }}
                        <button class="w-100" data-product-modal-trigger="{{ modalID }}">
                          <div class="main-product__faqs main-product__block space-between">
                            {% if _b.label != blank %}
                              <div class="btn--link">{{ _b.label }}</div>
                            {% endif %}
                            <span class="btn--link">
                              {{ _b.link-text }}
                              {% render 'icons', icon_name: 'expand' %}
                            </span>
                          </div>
                        </button>

                        {% capture modalContent %}
                          <h4 class="h4">{{ _faq.title | metafield_tag }}</h4>

                          {% for block in _faq.faq_blocks.value %}
                            <accordion-tab class="accordion-tab {% if forloop.first %}accordion-tab--open{% endif %}" data-accordion>
                              <div class="accordion-tab__title p-2" data-accordion-opener>{{ block.question }}</div>
                              {% render 'icons', icon_name: 'caret-down' %}
                              <div class="accordion-tab__content p-4">{{ block.answer | metafield_tag }}</div>
                            </accordion-tab>
                          {% endfor %}
                        {% endcapture %}
                        {% render 'product-modal',
                          id: modalID,
                          title: modalTitle,
                          content: modalContent
                        %}
                        <script src="{{ 'accordion-tab.min.js' | asset_url }}" defer="defer"></script>
                      {% endif %}
                    {% when 'report' %}
                      {% if _metafields.reports_results.value %}
                        <div {{ block.shopify_attributes }} class="main-product__report">

                          {{ _b.icon | image_url: width: _b.icon.width | image_tag: class: '' }}


                          <div class="main-product__report-text">
                            {% if _b.copy != blank %}
                              <p class="p-2">{{ _b.copy }}</p>
                            {% endif %}
                            {% liquid
                              assign _report = _metafields.reports_results.value
                              assign modalID = 'report'
                              assign modalTitle = 'Reports & Results'
                            %}
                            {% if _report != blank %}
                              <button class="product-form__link" data-product-modal-trigger="{{ modalID }}">{{ _b.link-text }}</button>

                              {% capture modalContent %}
                                <h4 class="h4">{{ _report.title }}</h4>
                                <p class="p-4">{{ _report.copy }}</p>

                                {% for block in _report.content_blocks.value %}
                                  <accordion-tab class="accordion-tab accordion-tab--open">
                                    <div class="s-3">{{ block.title }}</div>
                                    {% render 'image', image: block.icon %}
                                    <div class="accordion-tab__content">{{ block.copy | metafield_tag }}</div>
                                  </accordion-tab>
                                {% endfor %}
                              {% endcapture %}
                              {% render 'product-modal', id: modalID, title: modalTitle, content: modalContent %}
                            {% endif %}
                          </div>
                        </div>
                      {% endif %}
                    {% when 'product_features' %}
                      {% assign features = _metafields.product_features.value %}
                      <div {{ block.shopify_attributes }} class="grid grid--features">
                        {% for feature in features %}
                          <div>
                            {{ feature.icon | image_url: width: feature.icon.width | image_tag: class: '' }}
                            <span class="main-product__features-copy p-4">{{ feature.copy }}</span>
                          </div>
                        {% endfor %}
                      </div>
                    {% when 'bundled_products' %}
                      {% if product.metafields.custom.bundled_products != blank %}
                        {% assign subproducts = product.metafields.custom.bundled_products.value %}
                        <div class="bundled-products">
                          <div class="p-3 bundled-products__heading">Includes{% if subproducts.size %} {{ subproducts.size }} items{% endif %}:</div>
                          <ul class="bundled-products__list">
                            {% for subproduct in subproducts %}
                              <li class="bundled-products__product">
                                  <a href="{{ subproduct.url }}" class="p-4 btn--link">{{ subproduct.title }}</a>
                              </li>
                            {% endfor %}
                          </ul>
                        </div>
                      {% endif %}
                    {%- when 'variant_picker' -%}
                      <product-form {{ block.shopify_attributes }} 
                        data-variants="{{ product.variants | json | escape }}">
                        <div class="product-form">
                          {% assign randomNumber = 'now' | date: '%N' | modulo: 100 %}
                          {% assign formId = section.id
                            | append: '-'
                            | append: product.id
                            | append: '-'
                            | append: randomNumber
                          %}
                          {% render 'product-options', product: product, id: formId, _metafields: _metafields %}

                          {% if product.selling_plan_groups.first != blank %}
                            {% liquid
                              assign subscription_tooltip_text = block.settings.subscription_tooltip_text
                              assign discount = product.selling_plan_groups.first.selling_plans.first.price_adjustments.first.value
                              assign discountPercent = 100 | minus: discount | divided_by: 100.0
                              assign modalID = 'subscribe'
                              assign modalTitle = 'Subscription Details'
                            %}
                            {% assign modalTitle = 'Subscription Details' %}

                            <subscription-block data-tooltip-text="{{ subscription_tooltip_text | escape }}" data-subscription-discount="{{ discountPercent }}">
                              <div class="main-product__subscription main-product__block" data-current-selling-plan="{{ product.selling_plan_groups[0].selling_plans[0].id }}">
                                <div class="space-between">
                                  <h6 class="p-4">Subscribe:</h6>

                                  <button id="subscribe-tooltip" class="product-form__link">{{ modalTitle }}</button>
                                </div>
                                <div class="main-product__subscription-toggle">
                                  <div class="space-between">
                                    <div>
                                      <input class="input--radio" type="radio" name="sub-toggle" value="one-time" data-sub-toggle data-sub-toggle-one checked id="one-time" data-price="{{ variant.price }}">
                                      <label for="one-time" class="p-4">Buy Once</label>
                                    </div>
                                    <span class="p-4">
                                      {% render 'price', price: product.variants.first.price, class: 'color-noir', sub_toggle: true %}
                                    </span>
                                  </div>
                                  <div class="space-between">
                                    <div>
                                      <input class="input--radio" type="radio" name="sub-toggle" value="subscription" data-sub-toggle data-sub-toggle-subscription id="subscription" data-price="{{ variant.price | times: discountPercent }}">
                                      <label for="subscription" class="p-4">Subscribe & Save {{ discount }}% + Ship Free</label>
                                    </div>
                                    {% assign sub_price = product.variants.first.price | times: discountPercent | round: 0 %}
                                    <span class="p-4">
                                      {% render 'price', price: sub_price, class: 'price--sub', sub_toggle: true %}
                                    </span>
                                  </div>

                                  {% if product.selling_plan_groups[0].selling_plans.size > 1 %}
                                    <select-element data-subscription-toggle>
                                      <div class="custom-select">
                                        <button
                                          role="combobox"
                                          data-button="select"
                                          value="Select"
                                          aria-controls="listbox"
                                          aria-haspopup="listbox"
                                          tabindex="0"
                                          aria-expanded="false"
                                        >
                                          <span data-text="buttonText">Select Frequency:</span>
                                          {% render 'icons', icon_name: 'caret-down-small', class: 'icon-select' %}
                                        </button>
                                        <ul role="listbox" data-listbox>
                                          {% liquid
                                            assign is3Months = false
                                            for selling_plan_group in product.selling_plan_groups[0]
                                              assign label = selling_plan_group.selling_plans.name | remove: ' Ships every '
                                              if label contains '3 month'
                                                assign is3Months = true
                                                break
                                              endif
                                            endfor
                                          %}

                                          {% for selling_plan_group in product.selling_plan_groups[0].selling_plans %}
                                            {% liquid
                                              assign label = selling_plan_group.name | remove: 'Ships every'

                                              if forloop.first and is3Months == false
                                                assign isFirstNoDefault = true
                                              else
                                                assign isFirstNoDefault = false
                                              endif
                                              if is3Months == true and label contains '3 month'
                                                assign isDefault = true
                                              else
                                                assign isDefault = false
                                              endif
                                            %}
                                            <li role="option" data-selling-plan="{{ selling_plan_group.id }}" {% if isFirstNoDefault or isDefault  %}class="active"{% endif %}>
                                              Deliver <b>every {{ label }}</b>
                                              {% if isFirstNoDefault or isDefault  %}
                                                • recommended
                                              {% endif %}
                                            </li>
                                          {% endfor %}
                                        </ul>
                                        <div data-icon>
                                          {% render 'icons', icon_name: 'arrow-down' %}
                                        </div>
                                      </div>
                                    </select-element>
                                  {% endif %}
                                </div>
                              </div>
                            </subscription-block>

                            <script src="{{ 'subscription-block.min.js' | asset_url }}" defer></script>
                          {% endif %}

                          {% render 'buy-buttons',
                            product: product,
                            show_dynamic_checkout: _b.show_dynamic_checkout
                          %}
                        </div>
                      </product-form>
                      <script src="{{ 'main-product.min.js' | asset_url }}" defer="defer"></script>
                      <notify-form>
                        {%- form 'product',
                          product,
                          id: 'back-in-stock-form',
                          novalidate: 'novalidate',
                          class: 'main-product__notify-form',
                          data-type: 'notify-form',
                          method: 'post',
                          action: '/',
                          data-back-in-stock: 'true'
                        -%}
                          {% if isBackInStock %}
                            <div
                              class="main-product__back-in-stock{% if product.selected_or_first_available_variant.available == true %} hide{% endif %}"
                              data-notify-form
                            >
                              <div class="main-product__back-in-stock-copy">
                                <span class="main-product__back-in-stock-copy-text p-3">
                                  {{- 'products.product.back_in_stock_text' | t -}}
                                </span>
                                <span class="main-product__back-in-stock-copy-success p-3">
                                  {{- 'products.product.back_in_stock_thanks' | t -}}
                                </span>
                                <span class="main-product__back-in-stock-copy-error color-red p-3">
                                  {{- 'products.product.back_in_stock_error' | t -}}
                                </span>
                              </div>
                              <div class="main-product__back-in-stock-form">
                                <input
                                  type="email"
                                  placeholder="Email Address"
                                  id="pdp_bis_email"
                                  data-notify-email
                                  class="main-product__back-in-stock-form-email main"
                                >
                                <button
                                  type="submit"
                                  class="btn btn--primary main-product__back-in-stock-form-button"
                                  data-notify-submit-btn
                                  data-submit-button
                                >
                                  {{ 'products.product.back_in_stock_button' | t }}
                                </button>
                              </div>
                            </div>
                          {% endif %}
                        {% endform %}
                      </notify-form>


                    {% when 'selectable_bundle' %}
                      {% render 'selectable-bundle', block: block, _b: _b %}
                   

                    {% when 'rewards' %}
                      <div {{ block.shopify_attributes }} class="main-product__rewards space-between">
                        <div class="p-4">
                          Earn
                          {% render 'icons', icon_name: 'sparkle' %}
                          <span data-lion-points-possible></span>
                          with Grande Rewards.
                        </div>
                        <a href="/pages/loyalty" class="btn--link">Join Now</a>
                      </div>
                    {% when 'accordions' %}
                      {% capture accordion_icons %}
                        {% render 'icons', icon_name: 'plus' %}
                        {% render 'icons', icon_name: 'minus' %}
                      {% endcapture %}

                      <main-product__info-blocks
                        {{ block.shopify_attributes }}
                        class="main-product__tabs main-product__tabs--description" >
                        {% if product.description != blank %}
                          <div id="prod-description" class="main-product__tab main-product__tab--description accordion--expanded" data-accordion="description">
                            <div class="main-product__tab-title p-3" data-tab="description">
                              {{ accordion_icons }}
                              Description
                            </div>
                            <div class="main-product__tab-text__container">
                              <div class="main-product__tab-text p-4">
                                {{ product.description }}
                              </div>
                            </div>
                          </div>
                        {% endif %}
                        {% if _metafields.how_to_use != blank %}
                          <div class="main-product__tab main-product__tab--howtouse" data-accordion="howtouse">
                            <div class="main-product__tab-title p-3" data-tab="howtouse">
                              {{ accordion_icons }}
                              How to Use
                            </div>
                            <div class="main-product__tab-text__container">
                              <div class="main-product__tab-text p-4">
                                {{ _metafields.how_to_use | metafield_tag }}
                              </div>
                            </div>
                          </div>
                        {% endif %}
                        {% if _metafields.ingredients != blank %}
                          {% assign ingredients = _metafields.ingredients.value %}
                          <div class="main-product__tab main-product__tab--ingredients" data-accordion="ingredients">
                            <div class="main-product__tab-title p-3" data-tab="ingredients">
                              {{ accordion_icons }}
                              Ingredients
                            </div>
                            <div class="main-product__tab-text__container">
                              <div class="main-product__tab-text p-4">
                                {% for ingredient in ingredients %}
                                  <div class="main-product__ingredient">
                                    {% if ingredient.icon != blank %}
                                      {{ ingredient.icon | image_url: width: ingredient.icon.width | image_tag: class: '' }}
                                    {% endif %}
                                    <div class="main-product__ingredient--text">
                                      <p class="main-product__ingredient--title p-5 w-bold">{{ ingredient.title }}</p>
                                      <p class="main-product__ingredient--copy p-4">{{ ingredient.copy }}</p>
                                    </div>
                                  </div>
                                {% endfor %}
                                {% if _metafields.ingredients_list != blank %}
                                  <div class="main-product__ingredient--title p-5 w-bold">Ingredients List:</div>
                                  <div class="main-product__ingredient--copy p-4">{{ _metafields.ingredients_list }}</div>
                                {% endif %}
                              </div>
                            </div>
                          </div>
                        {% endif %}
                      </main-product__info-blocks>
                    {% when 'details' %}
                      {% if product.metafields.custom.details != blank %}
                        <main-product__info-blocks 
                          {{ block.shopify_attributes }}
                          class="main-product__tabs main-product__tabs--details">
                          <div class="main-product__tab">
                            <div class="main-product__tab-details">
                              <div class="main-product__tab-title p-3">{{ _b.details_heading }} {% render 'icons', icon_name: 'plus' %}{% render 'icons', icon_name: 'minus' %}</div>
                              <div class="main-product__tab-text__container">
                                <div class="main-product__tab-text p-3">
                                  <div class="main-product__tab-inner">
                                    {{ product.metafields.custom.details | metafield_tag }}
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>
                        </main-product__info-blocks>
                      {% endif %}
                  {% when 'warranty' %}
                    {% if product.metafields.custom.warranty != blank %}
                      <main-product__info-blocks 
                        {{ block.shopify_attributes }}
                        class="main-product__tabs main-product__tabs--warranty">
                        <div class="main-product__tab">
                          <div class="main-product__tab-warranty">
                            <div class="main-product__tab-title p-3">{{ _b.warranty_heading }} {% render 'icons', icon_name: 'plus' %}{% render 'icons', icon_name: 'minus' %}</div>
                            <div class="main-product__tab-text__container">
                              <div class="main-product__tab-text p-3">
                                <div class="main-product__tab-inner">
                                  {{ product.metafields.custom.warranty | metafield_tag }}
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </main-product__info-blocks>
                    {% endif %}
                  {% when 'pdf' %}
                    {% if product.metafields.custom.pdf_guides != blank %}
                      <main-product__info-blocks 
                        {{ block.shopify_attributes }}
                        class="main-product__tabs main-product__tabs--pdf_guides">
                        <div class="main-product__tab">
                          <div class="main-product__tab-pdf_guides">
                            <div class="main-product__tab-title p-3">{{ _b.pdf_heading }} {% render 'icons', icon_name: 'plus' %}{% render 'icons', icon_name: 'minus' %}</div>
                            <div class="main-product__tab-text__container">
                              <div class="main-product__tab-text p-3">
                                <div class="main-product__tab-inner">
                                  {{ product.metafields.custom.pdf_guides | metafield_tag }}
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </main-product__info-blocks>
                    {% endif %}
                {%- endcase -%}
            {%- endfor -%}
          </div>
        </product-info>
      </div>
    </div>
  </div>

  <div class="main-product__sticky-bar" data-sticky-add-to-cart>
    <div class="space-between">
      <span>
        {% render 'image', image: product.images.first, class: 'main-product__sticky-bar-image hide-mobile' %}
        <span class="main-product__sticky-bar-title p-3">{{ product.title }}</span>
      </span>
      <span>
        <span class="edit-group">
          {% assign sticky_title = product.variants.first.title | downcase %}
          {% unless sticky_title == 'default title' %}
            <span class="p-3" data-sticky-variant-title>{{ product.variants.first.title }}</span>
          {% endunless %}
          <a href="#top" class="btn--link">Edit</a>
        </span>
        <button class="btn btn--primary {% if product.selected_or_first_available_variant.available == false or quantity_rule_soldout  %}disabled{% endif %}" onclick="document.querySelector('[data-add-to-cart-btn]').click();" data-sticky-add-to-cart-btn>
          <span class="text-unavailable">{{ 'products.product.sold_out' | t }}</span>
          <span class="text-available">
            {{ 'products.product.add_to_cart' | t }}
            •
            {% render 'price', target: product.variants.first %}
          </span>
        </button>
      </span>
    </div>
  </div>
  <div class="main-product__sticky-mobile-watcher" data-mobile-sticky-watcher></div>
  <style>
    .footer {
      padding-bottom: 115px;

    }
    @media (min-width: 1024px) {
      .footer {
        padding-bottom: 63px;
      }
    }
  </style>
</section>

{% schema %}
{
  "name": "Main Product",
  "enabled_on": {
    "templates": ["product"]
  },
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "promo-text",
      "name": "Promo Text",
      "limit": 1
    },
    {
      "type": "short_desc",
      "name": "Short Description",
      "limit": 1
    },
    {
      "type": "promo_carousel",
      "name": "Promo Carousel",
      "limit": 1
    },
    {
      "type": "product_features",
      "name": "Product Features",
      "limit": 1
    },
    {
      "type": "bundled_products",
      "name": "Bundled Products",
      "limit": 1
    },
    {
      "type": "selectable_bundle",
      "name": "Selectable Bundle",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "label": "Show Dynamic Buy Buttons",
          "id": "show_dynamic_checkout",
          "default": true
        },
        {
          "type": "richtext",
          "label": "Subscription Tooltip Text",
          "id": "subscription_tooltip_text"
        }
      ]
    },
    {
      "type": "variant_picker",
      "name": "Variants",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "label": "Show Dynamic Buy Buttons",
          "id": "show_dynamic_checkout",
          "default": true
        },
        {
          "type": "richtext",
          "label": "Subscription Tooltip Text",
          "id": "subscription_tooltip_text"
        }
      ]
    },
    {
      "type": "shipping_details",
      "name": "Shipping Details",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "label": "Shiiping Info Text",
          "id": "shipping_details_text"
        }
      ]
    },
    {
      "type": "rewards",
      "name": "Rewards",
      "limit": 1
    },
    {
      "type": "accordions",
      "name": "Accordions",
      "limit": 1
    },
    {
      "type": "details",
      "name": "Details",
      "settings": [
        {
          "type": "text",
          "id": "details_heading",
          "default": "Details",
          "label": "Heading"
        }
      ],
      "limit": 1
    },
    {
      "type": "warranty",
      "name": "Warranty",
      "settings": [
        {
          "type": "text",
          "id": "warranty_heading",
          "default": "Warranty",
          "label": "Heading"
        }
      ],
      "limit": 1
    },
    {
      "type": "pdf",
      "name": "PDF Guides",
      "settings": [
        {
          "type": "text",
          "id": "pdf_heading",
          "default": "PDF Guides",
          "label": "Heading"
        }
      ],
      "limit": 1
    },
