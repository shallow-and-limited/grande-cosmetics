<div
  class="color-{{ section.settings.color_scheme }} gradient"
>
  <div class="full-width section-{{ section.id }}-padding">
    <div class="utility-bar">
      <div class="utility-bar__container">
        {%- if section.settings.link != blank -%}
          <a
            href="{{ section.settings.link }}"
            class="link full-unstyled-link"
          >
            {{ section.settings.text }}
          </a>
        {%- else -%}
          {{ section.settings.text }}
        {%- endif -%}
      </div>

      <ul class="utility-bar__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'utility' -%}
            <li class="utility-bar__item">
              <a class="link link--hover utility-bar__link" href="{{ block.settings.link }}">
                {% if block.settings.icon != blank %}
                  <div class="utility-bar__icon">
                    {{ block.settings.icon }}
                  </div>
                {% endif %}
                {{ block.settings.text }}
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  </div>
</div>

{% javascript %}
  document.addEventListener('DOMContentLoaded', function () {
    const announcementBar = document.querySelector('.utility-bar');

    if (announcementBar) {
      document.documentElement.style.setProperty('--announcement-height', `${announcementBar.offsetHeight}px`);
    }
  });
{% endjavascript %}

{% schema %}
{
  "name": "Annoucement Bar",
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section settings"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-3"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "text",
      "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:sections.announcement-bar.blocks.announcement.settings.link.label"
    }
  ],
  "blocks": [
    {
      "type": "utility",
      "name": "Utility Link",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "textarea",
          "id": "icon",
          "label": "Icon SVG Code"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
  ],
  "presets": [
    {
      "name": "Annoucement Bar"
    }
  ]
}
{% endschema %}
