{{ 'press-cards.min.css' | asset_url | stylesheet_tag }}
{{ 'blog-card.min.css' | asset_url | stylesheet_tag }}

{% liquid
  assign _s = section.settings
  assign _blog = _s.blog
  assign _blocks = section.blocks
%}

<press-cards class="press-cards">
  <div class="press-cards__header space-between">
    <div>
      {% if _s.title != blank %}
        <h4 class="h4">{{ _s.title }}</h4>
      {% endif %}
    </div>
    {% if _blocks.size == 0 %}
      <div>
        {% if _s.link_text != blank %}
          <a class="btn--link" href="{{ _blog.url }}">{{ _s.link_text }}</a>
        {% endif %}
      </div>
    {% endif %}
  </div>
  <div class="swiper" data-press-cards-carousel data-count="{{ _blog.articles.size }}">
    <div class="swiper-wrapper">
      {% if _blog != blank %}
        {% for i in (1..2) %}
          {% for article in _blog.articles limit: 10 %}
            <div class="swiper-slide">
              {% render 'blog-card', article: article, card_index: forloop.index %}
            </div>
          {% endfor %}
        {% endfor %}
      {% else %}
        {% for block in _blocks %}
          {% assign _settings = block.settings %}                 
          <div class="main-blog-card-content blog-card swiper-slide" {% if _blocks_size > 2 %} data-swiper-class="swiper-slide"{% endif %} data-category="{{ _settings.card | downcase | replace: ' ', '-' }}" data-slide-up >
            <div class="main-blog-card__image-wrapper">
              <a href="{{ _settings.cta_url }}">                
                {% assign _image = _settings.image %}                
                <img
                  class="main-blog-card__image"
                  src="{{ _image | image_url: width: 500 }}"
                  alt="Image for article"
                  loading="lazy"
                >                
              </a>
            </div>
            <div class="main-blog-card-inner">
              {% if _settings.eyebrow != blank -%}
                <div class="eyebrow main-blog-card-tags p-4">
                  <p class="tag color-dark-gray">{{ _settings.eyebrow }}</p>
                </div>
              {%- endif -%}
              {% if _settings.heading != blank -%}
                <h5 class="p-4 main-blog-card-title">{{ _settings.heading }}</h5>
              {%- endif -%}              
              {% assign _copy = block.settings.copy %}                        
              {% if _settings.copy != blank -%}
                <p class="main-blog-card-excerpt p-3">{{ _copy }}</p>
              {%- endif -%}
              {% if _settings.cta_copy != blank and _settings.cta_url != blank %}
                <a href="{{ _settings.cta_url }}" class="p-3 color-rose">{{ _settings.cta_copy }}</a>
              {%- endif -%}              
            </div>
          </div>         
        {% endfor %}
      {% endif %}
    </div>
    <div class="swiper-scrollbar hide-desktop">
      <div class="swiper-scrollbar-drag"></div>
    </div>
  </div>
  {% if _blocks.size > 3 or _blog.articles.size > 3 %}
    <div class="press-cards__controls hide-mobile">
      <button class="pager pager-prev" data-previous aria-label="Previous Carousel Slide">
        {% render 'icons', icon_name: 'arrow-left' %}
      </button>
      <button class="pager pager-next" data-next aria-label="Next Carousel Slide">
        {% render 'icons', icon_name: 'arrow-right' %}
      </button>
    </div>
  {% endif %}
</press-cards>

<script src="{{ 'press-cards.min.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Press (Cards)",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "View All"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    }
  ],
  "blocks": [
    {
      "type": "content",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },        
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy"
        },
        {
          "type": "text",
          "id": "cta_copy",
          "label": "CTA Copy",
          "default": "read more"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "CTA Url"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Press (Cards)"
    }
  ]
}
{% endschema %}