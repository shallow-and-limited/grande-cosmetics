{{ 'ticker.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  id="{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding isolate"
>
  <div class="{{ section.settings.layout }}">
    <div class="ticker">
      {%- for x in (1..2) -%}
        <div
          class="ticker__inner {{ section.settings.text_style }} {{ section.settings.mobile_text_style }}"
          aria-hidden="{{ forloop.last }}"
          style="            --duration: {{ section.settings.duration }}s;"
        >
          {%- for block in section.blocks -%}
            <div class="ticker__item">
              {%- if block.settings.image != blank -%}
                <div
                  class="ticker__item-image"
                  style="width: {{ block.settings.image_width }}"
                >
                  <div
                    class="media media--adapt"
                    style="padding-bottom: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;"
                  >
                    {{
                      block.settings.image
                      | image_url: width: 1500
                      | image_tag: alt: block.settings.image.alt
                    }}
                  </div>
                </div>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="ticker__item-text">
                  {{ block.settings.text }}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Ticker",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "screen-width",
          "label": "Screen width"
        },
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "text_style",
      "options": [
        {
          "value": "body--xsmall",
          "label": "X-Small"
        },
        {
          "value": "body--small",
          "label": "Small"
        },
        {
          "value": "body",
          "label": "Regular"
        },
        {
          "value": "body--large",
          "label": "Large"
        }
      ],
      "default": "body",
      "label": "Text style"
    },
    {
      "type": "select",
      "id": "mobile_text_style",
      "options": [
        {
          "value": "body--xsmall-mobile",
          "label": "X-Small"
        },
        {
          "value": "body--small-mobile",
          "label": "Small"
        },
        {
          "value": "body-mobile",
          "label": "Regular"
        },
        {
          "value": "body--large-mobile",
          "label": "Large"
        }
      ],
      "default": "body-mobile",
      "label": "Mobile text style"
    },
    {
      "type": "range",
      "id": "duration",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "Duration",
      "default": 30
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "ticker",
      "name": "Ticker",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_width",
          "label": "Image width",
          "default": "120px"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ticker"
    }
  ]
}
{% endschema %}
