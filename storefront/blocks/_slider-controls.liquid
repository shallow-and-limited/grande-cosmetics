{% render 'slider_controls', 
  section: section,
  hide_desktop: block.settings.hide_desktop,
  hide_mobile: block.settings.hide_mobile,
  show_dots: block.settings.show_dots,
  show_arrows: block.settings.show_arrows,
  show_pause_button: block.settings.show_pause_button
%}

{% schema %}
{
  "name": "Slider Controls",
  "tag": null,
  "settings": [
    {
      "type": "checkbox",
      "id": "hide_desktop",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show navigation dots",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pause_button",
      "label": "Show pause button",
      "default": true
    }
  ]
}
{% endschema %}