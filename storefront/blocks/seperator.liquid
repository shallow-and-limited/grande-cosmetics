<hr 
  class="seperator"
  style="
    background-color: {{ block.settings.color }};
    height: {{ block.settings.height }}px;
    margin: {{ block.settings.margin }}px 0;
  "
>

{% schema %}
{
  "name": "Seperator",
  "settings": [
    {
      "type": "range",
      "id": "height",
      "label": "t:sections.general.height",
      "default": 1,
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin",
      "label": "t:sections.general.margin",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "t:sections.general.style_overrides"
    },
    {
      "type": "color",
      "id": "color",
      "label": "t:sections.general.color"
    }
  ],
  "presets": [
    { "name": "Seperator" }
  ]
}
{% endschema %}