<slider-component
  role="region"

  data-loop="{{ block.settings.slider_loop }}"
  data-autoplay="{{ block.settings.slider_autoplay }}"

  {% if block.settings.slider_autoplay %}
    data-speed="{{ block.settings.slider_speed | times: 1000 }}"
  {% endif %}

  {% if block.settings.slider_loop %}
    aria-roledescription="{{ 'slider.carousel' | t }}"    
  {% endif %}

  {% if block.settings.accessibility_info != blank %}
    aria-label="{{ block.settings.accessibility_info | escape }}"
  {% endif %}
>
  <ul
    id="Slider-{{ block.id }}"
    class="
      grid
      grid--{{ block.settings.columns_desktop | handle }}-col-desktop
      grid--{{ block.settings.columns_mobile | handle }}-col-mobile
      slider
      {% if block.settings.enable_desktop_slider %}slider--desktop{% endif %}
      {% if block.settings.enable_mobile_slider %}slider--mobile{% endif %}
    "
    role="list"
    aria-label="{{ 'slider.name' | t }}"
  >
    {% content_for 'blocks' %}
  </ul>

  {% if block.settings.enable_desktop_slider or block.settings.enable_mobile_slider %}
    {% content_for 'block', type: '_slider-controls', id: 'slider-controls' %}
  {% endif %}
</slider-component>

{% schema %}
{
  "name": "Grid",
  "blocks": [
    {
      "type": "_grid-item"
    },
    {
      "type": "_media-card"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Grid settings"
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider",
      "label": "Enable desktop slider",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_mobile_slider",
      "label": "Enable mobile slider",
      "default": true
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 7.5,
      "step": 0.5,
      "default": 3,
      "label": "t:sections.collection-list.settings.columns_desktop.label"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3.5,
      "step": 0.5,
      "default": 1,
      "label": "Number of columns on mobile"
    },
    {
      "type": "header",
      "content": "Slider settings"
    },
    {
      "type": "text",
      "id": "accessibility_info",
      "label": "Accessibility info",
      "info": "Describe the slider for customers using screen readers"
    },
    {
      "type": "checkbox",
      "id": "slider_autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "visible_if": "{{ block.settings.slider_autoplay }}",
      "type": "range",
      "id": "slider_speed",
      "label": "Slideshow speed",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 5,
      "unit": "s"
    },
    {
      "type": "checkbox",
      "id": "slider_loop",
      "label": "Loop",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Grid Items",
      "category": "Content",
      "blocks": [
        {
          "name": "Grid Item",
          "type": "_grid-item",
          "blocks": [
            { "name": "Group", "type": "group" }
          ]
        },
        {
          "name": "Grid Item",
          "type": "_grid-item",
          "blocks": [
            { "name": "Group", "type": "group" }
          ]
        },
        {
          "name": "Grid Item",
          "type": "_grid-item",
          "blocks": [
            { "name": "Group", "type": "group" }
          ]
        },
        {
          "name": "Grid Item",
          "type": "_grid-item",
          "blocks": [
            { "name": "Group", "type": "group" }
          ]
        }
      ]
    }
  ]
}
{% endschema %}