<{{ block.settings.heading_tag }}
  class="{{ block.settings.heading_size }}--desktop {{ block.settings.heading_size_mobile }}--mobile"
  style="
    {% if block.settings.color != blank and block.settings.color.alpha != 0 %}
      color: {{ block.settings.color }};
    {% endif %}
  "
  {{ block.shopify_attributes }}
>
  {{- block.settings.heading -}}
</{{ block.settings.heading_tag }}>

{% schema %}
{
  "name": "Heading",
  "settings": [
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "h1"
        },
        {
          "value": "h2",
          "label": "h2"
        },
        {
          "value": "h3",
          "label": "h3"
        },    
        {
          "value": "h4",
          "label": "h4"
        },
        {
          "value": "h5",
          "label": "h5"
        },
        {
          "value": "h6",
          "label": "h6"
        },
        {
          "value": "div",
          "label": "div"
        },
        {
          "value": "span",
          "label": "span"
        },
        {
          "value": "p",
          "label": "p"
        }
      ],
      "default": "h2",
      "label": "Heading tag",
      "info": "The tag to use for the heading. This is the HTML tag that will be used to wrap the heading."
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.general.heading",
      "default": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h6",
          "label": "t:sections.general.xx_small"
        },
        {
          "value": "h5",
          "label": "t:sections.general.x_small"
        },
        {
          "value": "h4",
          "label": "t:sections.general.small"
        },
        {
          "value": "h3",
          "label": "t:sections.general.medium"
        },
        {
          "value": "h2",
          "label": "t:sections.general.large"
        },
        {
          "value": "h1",
          "label": "t:sections.general.x_large"
        }
      ],
      "default": "h2",
      "label": "t:sections.general.header_size"
    },
    {
      "type": "select",
      "id": "heading_size_mobile",
      "options": [
        {
          "value": "h6",
          "label": "t:sections.general.xx_small"
        },
        {
          "value": "h5",
          "label": "t:sections.general.x_small"
        },
        {
          "value": "h4",
          "label": "t:sections.general.small"
        },
        {
          "value": "h3",
          "label": "t:sections.general.medium"
        },
        {
          "value": "h2",
          "label": "t:sections.general.large"
        },
        {
          "value": "h1",
          "label": "t:sections.general.x_large"
        }
      ],
      "default": "h2",
      "label": "t:sections.general.header_size_mobile"
    },    
    {
      "type": "header",
      "content": "t:sections.general.style_overrides"
    },
    {
      "type": "color",
      "id": "color",
      "label": "t:sections.general.text_color"
    }
  ],
  "presets": [{ "name": "Heading" }]
}
{% endschema %}
