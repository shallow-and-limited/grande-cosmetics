<div class="styleguide__buttons">
  <p class="p-2 uc strong">Primary Button - On light</p>
  <div class="styleguide__button">
    <div>
      <button class="btn btn--primary">Shop Now</button>
      <p class="p-3">Default</p>
    </div>
    <div>
      <button class="btn btn--primary btn--hover">Shop Now</button>
      <p class="p-3">Hover</p>
    </div>
    <div>
      <button class="btn btn--primary btn--focus">Shop Now</button>
      <p class="p-3">Focused</p>
    </div>
    <div>
      <button class="btn btn--primary disabled">Shop Now</button>
      <p class="p-3">Disabled</p>
    </div>
  </div>
</div>
<div class="styleguide__buttons bg-rose">
  <p class="p-2 uc strong color-white">Primary Button - On Dark</p>
  <div class="styleguide__button">
