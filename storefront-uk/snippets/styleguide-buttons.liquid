<div class="styleguide__buttons bg-light-grey">
  <p class="p-2 uc strong">Tabs - On Light</p>
  <tabs-element class="tabs">
    <div class="swiper" data-tabs-carousel>
      <div class="swiper-wrapper">
        <div class="swiper-slide">
          <button class="p-2 tab tab--selected" data-tab>Category 1</button>
        </div>
        <div class="swiper-slide">
          <button class="p-2 tab" data-tab>Category 2</button>
        </div>
        <div class="swiper-slide">
          <button class="p-2 tab" data-tab>Category 3</button>
        </div>
        <div class="swiper-slide">
          <button class="p-2 tab" data-tab>Category 4</button>
        </div>
        <div class="swiper-slide">
          <button class="p-2 tab" data-tab>Category 5</button>
        </div>
        <div class="swiper-slide">
          <button class="p-2 tab" data-tab>Category 6</button>
        </div>
        <div class="swiper-slide">
          <button class="p-2 tab" data-tab>Category 7</button>
        </div>
      </div>
    </div>
  </tabs-element>
</div>
<div class="styleguide__buttons bg-rose">
  <p class="p-2 uc strong color-white">Tabs - On Dark</p>
  <tabs-element class="tabs--dark">
    <button class="p-2 w-bold tab tab--selected" data-tab>Connect</button>
    <button class="p-2 w-bold tab" data-tab>Shop</button>
    <button class="p-2 w-bold tab" data-tab>Rewards</button>
    <button class="p-2 w-bold tab" data-tab>Jobs</button>
    <button class="p-2 w-bold tab" data-tab>Learn</button>
  </tabs-element>
</div>
<div class="styleguide__buttons">
  <p class="p-2 uc strong">Text Link – On Light</p>
  <div class="styleguide__button">
    <div>
      <button class="btn btn--text">Default</button>
    </div>
    <div>
      <button class="btn btn--text btn--hover">Hover</button>
    </div>
    <div>
      <button class="btn btn--text btn--focus">Focused</button>
    </div>
  </div>
</div>
<div class="styleguide__buttons bg-rose">
  <p class="p-2 uc strong color-white">Text Link – On Dark</p>
