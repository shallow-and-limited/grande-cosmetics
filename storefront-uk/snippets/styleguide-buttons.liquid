<div class="styleguide__play-buttons bg-light-grey">
  <p class="p-2 uc strong">Play / Pause Button</p>
  <div class="styleguide__play-button">
    <div class="button-container">
      <div class="btn--play">{% render 'icons', icon_name: 'play', class: 'play-btn' %}</div>
      <p class="p-3">Default</p>
    </div>
    <div class="button-container">
      <div class="btn--play btn--play-hover">{% render 'icons', icon_name: 'play', class: '' %}</div>
      <p class="p-3">Hover</p>
    </div>
    <div class="button-container">
      <div class="btn--pause">{% render 'icons', icon_name: 'pause', class: 'pause-btn' %}</div>
      <p class="p-3">Default</p>
    </div>
    <div class="button-container">
      <div class="btn--pause btn--pause-hover">{% render 'icons', icon_name: 'pause', class: 'pause-btn' %}</div>
      <p class="p-3">Hover</p>
    </div>
  </div>
</div>
