      <p class="p-3 color-white">Default</p>
    </div>
    <div>
      <button class="btn btn--primary-dark btn--hover">Shop Now</button>
      <p class="p-3 color-white">Hover</p>
    </div>
    <div>
      <button class="btn btn--primary-dark btn--focus">Shop Now</button>
      <p class="p-3 color-white">Focused</p>
    </div>
    <div>
      <button class="btn btn--primary-dark disabled">Shop Now</button>
      <p class="p-3 color-white">Disabled</p>
    </div>
  </div>
</div>
