{{ 'blog-carousel.min.css' | asset_url | stylesheet_tag }}

<section class="blog-carousel blog-carousel--{{ section.id }}">
  <div class="blog-carousel__container">
    <blog-carousel-carousel class="blog-carousel__slider" data-swiper-class="swiper">
      <div class="blog-carousel-carousel__slides" data-swiper-class="swiper-wrapper">
        {%  for block in section.blocks %}
          <div class="blog-carousel blog-carousel__slide {{ block.settings.placement }}{% if section.blocks.size == 1 %} single{%  endif %}" data-swiper-class="swiper-slide">
            <div class="blog-carousel__slide-wrapper">
              <div class="blog-carousel__slide-image blog-carousel__slide-fadeElement">
                {%  render 'image', image: block.settings.article.image  %}
              </div>
              <div class="blog-carousel__slide-content blog-carousel__slide-fadeElement {{ block.settings.text_align_m }} {{ block.settings.text_align_d }}">
                <div class="blog-carousel__slide-content__container">
                  <p class="eyebrow p-4 color-dark-gray">
                    {% for tag in block.settings.article.tags %}
                      <span class="tag"># {{ tag }}</span>
                    {% endfor %}
                  </p>
                  <h4>{{  block.settings.heading }}</h4>
                  <a href="{{ block.settings.article.url }}" class="p-3 color-rose">{{ block.settings.cta_copy }}</a>                
                </div>
              </div>
            </div>
          </div>
        {%  endfor %}
      </div>
      <div class="blog-carousel__nav-wrapper">
        <div class="blog-carousel__nav-spacer"></div>
        <div class="blog-carousel__nav">
          {% if section.blocks.size > 1 %}
            <div class="blog-carousel-carousel__pagination" data-pagination-blog></div>
            <div class="blog-carousel__nav-arrows">
              <button class="blog-carousel-carousel__prev hide-mobile" data-slide-previous-blog aria-label="Previous Carousel Slide">
                {% render 'icons', icon_name: 'arrow-left' %}
              </button>
              <button class="blog-carousel-carousel__next hide-mobile" data-slide-next-blog aria-label="Next Carousel Slide">
                {% render 'icons', icon_name: 'arrow-right' %}
              </button>                    
            </div>
          {% endif %}    
        </div>            
      </div>
    </blog-carousel-carousel>
  </div>
</section>

<script src="{{ 'blog-carousel.min.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Blog Carousel",
  "tag": "section",
  "settings": [],
  "blocks": [
    {
      "type": "blog_carousel_block",
      "name": "Blog Carousel Block",
      "settings": [
        {
          "type": "article",
          "id": "article",
          "label": "Article"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "cta_copy",
          "label": "CTA Copy"
        }
      ]
    }
  ],
  "presets": [
    {
      "category": "blog-carousel",
      "name": "Blog Carousel"
    }
  ]
}
{% endschema %}
