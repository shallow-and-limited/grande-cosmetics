{{ 'main-404.min.css' | asset_url | stylesheet_tag }}
{% assign _s = section.settings %}

<div class="main-404">
  {% unless _s.eyebrow == blank %}
    <div class="h5"><h5>{{ _s.eyebrow }}</h5></div>
  {% endunless %}
  {% unless _s.heading == blank %}
    <div class="h2"><h2>{{ _s.heading }}</h2></div>
  {% endunless %}
  {% unless _s.copy == blank %}
    <div class="p"><p>{{ _s.copy }}</p></div>
  {% endunless %}
  {% unless _s.cta_copy == blank %}
    <a href="{{ _s.cta_url }}" class="btn btn--primary">
      {{- _s.cta_copy -}}
    </a>
  {% endunless %}
</div>

{% schema %}
{
  "name": "404",
  "enabled_on": {
    "templates": ["404"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Page body text"
    },
    {
      "type": "text",
      "id": "cta_copy",
      "label": "CTA text"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ]
}
{% endschema %}